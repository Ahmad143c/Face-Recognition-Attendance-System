{
  "name": "face-recognition-attendance",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "face-api.js": "^0.22.2",
    "framer-motion": "^10.12.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.5.0",
    "util": "^0.12.5",
    "uuid": "^9.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "eject": "react-scripts eject"
  },
  "resolutions": {
    "source-map-loader": "^0.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "env": {
      "production": {
        "ESLINT_NO_DEV_ERRORS": "true"
      }
    }
  },
    "rules": {
      "react-hooks/exhaustive-deps": "warn",
      "no-use-before-define": "warn",
      "no-unused-vars": "warn"
    },
    "overrides": [
      {
        "files": ["**/*.js", "**/*.jsx"],
        "env": {
          "CI": {
            "es2020": true
          }
        },
        "rules": {
          "react-hooks/exhaustive-deps": "off",
          "no-use-before-define": "off",
          "no-unused-vars": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.7"
  }
}
